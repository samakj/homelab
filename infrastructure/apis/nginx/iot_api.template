server {
    listen ${ports.http};
    listen [::]:${ports.http};
    # listen ${ports.https} ssl http2;
    # listen [::]:${ports.https} ssl http2;

    server_name ~^${subdomains.iot_api}.*$;
    resolver 127.0.0.11;

    location / {
        proxy_pass $scheme://${containers.iot_api}:${ports.iot_api};

        include proxy.conf;

        access_log off;
    }
}