server {
    listen ${ports.https} default_server ssl http2;
    listen [::]:${ports.https} ssl http2;

    server_name ~^${subdomains.utilities_scraper}.*$;
    resolver 127.0.0.11;

    location / {
        proxy_pass $scheme://${containers.utilities_scraper}:${ports.utilities_scraper};

        include proxy.conf;
    }
}