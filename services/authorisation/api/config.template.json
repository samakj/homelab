{
    "secret": "${auth.secret}",
    "algorithm": "${auth.algorithm}",
    "db": {
        "host": "${containers.postgres}",
        "port": "${ports.postgres}",
        "name": "${postgres.authorisation.name}",
        "user": "${postgres.authorisation.name}",
        "password": "${postgres.authorisation.password}",
        "tables": {"users": "${postgres.authorisation.tables.users}", "sessions": "${postgres.authorisation.tables.sessions}"}
    },
    "cache": {
        "host": "${containers.redis}",
        "port": "${ports.redis}",
        "alias": {
            "${containers.authorisation_api}:${ports.authorisation_api}": "${containers.authorisation_api}",
            "${subdomains.authorisation_api}.${hosts.apis}": "${containers.authorisation_api}"
        }
    }
}